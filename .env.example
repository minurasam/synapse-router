# Gateway
SYNAPSE_HOST=0.0.0.0
SYNAPSE_PORT=8000
SYNAPSE_LOG_LEVEL=INFO
SYNAPSE_API_KEYS=dev-key-replace-me

# Backends (docker-compose service names in dev)
SYNAPSE_BACKEND_PHI3_URL=http://vllm-phi3:8000
SYNAPSE_BACKEND_MISTRAL_URL=http://vllm-mistral:8000
SYNAPSE_BACKEND_LLAMA_URL=http://vllm-llama:8000

# Classifier
SYNAPSE_CLASSIFIER_MODE=hybrid
SYNAPSE_CLASSIFIER_ONNX_PATH=classifier-artifacts/distilbert-complexity.onnx
SYNAPSE_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7

# Storage
SYNAPSE_REDIS_URL=redis://redis:6379/0
SYNAPSE_POSTGRES_URL=postgresql+asyncpg://synapse:synapse@postgres:5432/synapse

# Observability
SYNAPSE_OTEL_ENDPOINT=http://otel-collector:4317
SYNAPSE_PROMETHEUS_PORT=9090

# Judge (for bench only)
ANTHROPIC_API_KEY=